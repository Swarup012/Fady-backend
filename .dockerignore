# Docker ignore file for Fady Backend

# Dependencies (installed during build)
node_modules
npm-debug.log
yarn-error.log

# Environment files (passed as secrets)
.env
.env.*
!.env.example

# Git
.git
.gitignore
.gitattributes

# Testing files (EXCLUDED from production)
tests/
test/
__tests__/
*.test.js
*.spec.js
coverage/
.nyc_output/
jest.config.js

# Test scripts we created
tests/comprehensive-test-suite.js
tests/TESTING_GUIDE.md
test*.js
check*.js
debug*.js

# SQL migration files (run separately)
*.sql
supabase_*.sql
fix_*.sql
check_*.sql

# Documentation (NOT needed in container)
*.md
README.md
*_GUIDE.md
*_IMPLEMENTATION.md
*_COMPLETE.md
*_STATUS.md
DEPLOYMENT_*.md
DEBUG_*.md
FIXES_*.md
QUICK_*.md

# Development/Debug scripts
manage*.js
add-user-to-org.js
run_migration.js

# IDE files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
logs/
*.log

# Docker files
docker-compose.yml
Dockerfile
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml

# Temporary files
tmp/
temp/
term
*.tmp
